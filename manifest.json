{
  "manifest_version": 3,
  "name": "Leaflet Mark View",
  "short_name": "Leaflet MV",
  "version": "1.1.1",
  "author": "轻语",
  "description": "Read local & remote Markdown — folder browsing, math, Mermaid, syntax highlighting, Confluence export. Fully local, no uploads.",
  "homepage_url": "https://github.com/whisper-xiang/leaflet-mark-view",
  "minimum_chrome_version": "116",
  "background": {
    "service_worker": "background.js"
  },
  "permissions": ["storage"],
  "host_permissions": [
    "file:///*",
    "https://raw.githubusercontent.com/*",
    "https://api.github.com/*"
  ],
  "optional_host_permissions": ["https://*/*"],
  "content_scripts": [
    {
      "matches": ["file:///*"],
      "js": ["markdown.js", "content.js"],
      "run_at": "document_end",
      "all_frames": false
    }
  ],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "chrome_url_overrides": {
    "newtab": "home.html"
  },
  "web_accessible_resources": [
    {
      "resources": ["home.html", "home.js", "newtab-gate.js", "viewer.html", "viewer.css", "lmv-db.js", "remote-md.js", "README.md", "markdown.js"],
      "matches": ["<all_urls>"]
    }
  ]
}
